<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Админка меню</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="admin-body">
  <header class="admin-topbar">
    <div><strong>Админ-панель меню</strong><span>Редактирование QR-меню</span></div>
    <div class="top-actions">
      <a class="btn" href="/" target="_blank">Открыть меню</a>
      <form method="post" action="/admin/logout"><button class="btn danger">Выйти</button></form>
    </div>
  </header>

  <main class="admin-wrap">
    <% if (flash.success) { %><div class="alert success"><%= flash.success[0] %></div><% } %>

    <section class="panel">
      <h2>Настройки ресторана</h2>
      <form class="admin-form grid-form" method="post" action="/admin/settings" enctype="multipart/form-data">
        <label>Название <input name="restaurant_name" value="<%= settings.restaurant_name %>" required></label>
        <label>Подзаголовок <input name="restaurant_subtitle" value="<%= settings.restaurant_subtitle %>"></label>
        <label>Валюта <input name="currency" value="<%= settings.currency %>" required></label>
        <label>Основной цвет <input type="color" name="theme_color" value="<%= settings.theme_color %>"></label>
        <label>Акцент <input type="color" name="accent_color" value="<%= settings.accent_color %>"></label>
        <label class="wide">
          Обложка

          <% if (settings.cover_image) { %>
            <div class="admin-preview">
              <img src="<%= settings.cover_image %>?v=<%= Date.now() %>" alt="Обложка ресторана">
            </div>
          <% } %>

          <input type="file" name="cover_image" accept="image/*">
        </label>
        <button class="btn primary">Сохранить настройки</button>
      </form>
    </section>

    <section class="panel">
      <h2>Добавить раздел</h2>
      <form class="admin-form grid-form" method="post" action="/admin/categories">
        <label>Название <input name="title" required placeholder="Например: Завтраки"></label>
        <label>Описание <input name="description" placeholder="Короткое описание"></label>
        <label>Позиция <input name="position" type="number" value="0"></label>
        <label class="check"><input type="checkbox" name="is_active" checked> Показывать</label>
        <button class="btn primary">Добавить раздел</button>
      </form>
    </section>

    <section class="panel">
      <h2>Разделы</h2>
      <div class="admin-list">
        <% categories.forEach(cat => { %>
          <form class="row-card" method="post" action="/admin/categories/<%= cat.id %>">
            <input name="title" value="<%= cat.title %>" required>
            <input name="description" value="<%= cat.description %>" placeholder="Описание">
            <input name="position" type="number" value="<%= cat.position %>">
            <label class="check"><input type="checkbox" name="is_active" <%= cat.is_active ? 'checked' : '' %>> Показывать</label>
            <button class="btn">Сохранить</button>
            <button class="btn danger" formaction="/admin/categories/<%= cat.id %>/delete" onclick="return confirm('Удалить раздел и все блюда внутри?')">Удалить</button>
          </form>
        <% }) %>
      </div>
    </section>

    <section class="panel">
      <h2>Добавить позицию</h2>
      <form class="admin-form grid-form" method="post" action="/admin/items" enctype="multipart/form-data">
        <label>Раздел <select name="category_id" required><% categories.forEach(cat => { %><option value="<%= cat.id %>"><%= cat.title %></option><% }) %></select></label>
        <label>Название <input name="title" required></label>
        <label>Цена <input name="price" type="number" step="0.01" required></label>
        <label>Старая цена <input name="old_price" type="number" step="0.01"></label>
        <label>Вес/объем <input name="weight" placeholder="250 г / 350 мл"></label>
        <label>Позиция <input name="position" type="number" value="0"></label>
        <label class="wide">Описание <textarea name="description" rows="3"></textarea></label>
        <label>Бейджи <input name="badges" placeholder="vegan, spicy, chef"></label>
        <label>Аллергены <input name="allergens" placeholder="глютен, молоко"></label>
        <label>Фото <input type="file" name="image" accept="image/*"></label>
        <label class="check"><input type="checkbox" name="is_popular"> Популярное</label>
        <label class="check"><input type="checkbox" name="is_new"> Новинка</label>
        <label class="check"><input type="checkbox" name="is_active" checked> Показывать</label>
        <button class="btn primary">Добавить позицию</button>
      </form>
    </section>

    <section class="panel">
      <h2>Позиции меню</h2>
      <div class="items-admin-list">
        <% items.forEach(item => { %>
          <form class="item-edit-card" method="post" action="/admin/items/<%= item.id %>" enctype="multipart/form-data">
            <div class="thumb">
              <% if (item.image) { %>
                <img src="<%= item.image %>?v=<%= Date.now() %>" alt="<%= item.title %>">
              <% } else { %>
                🍽️
              <% } %>
            </div>
            <div class="edit-grid">
              <label>Раздел <select name="category_id"><% categories.forEach(cat => { %><option value="<%= cat.id %>" <%= cat.id === item.category_id ? 'selected' : '' %>><%= cat.title %></option><% }) %></select></label>
              <label>Название <input name="title" value="<%= item.title %>" required></label>
              <label>Цена <input name="price" type="number" step="0.01" value="<%= item.price %>" required></label>
              <label>Старая цена <input name="old_price" type="number" step="0.01" value="<%= item.old_price || '' %>"></label>
              <label>Вес <input name="weight" value="<%= item.weight %>"></label>
              <label>Позиция <input name="position" type="number" value="<%= item.position %>"></label>
              <label class="wide">Описание <textarea name="description"><%= item.description %></textarea></label>
              <label>Бейджи <input name="badges" value="<%= item.badges %>"></label>
              <label>Аллергены <input name="allergens" value="<%= item.allergens %>"></label>
              <label>Новое фото <input type="file" name="image" accept="image/*"></label>
              <label class="check"><input type="checkbox" name="is_popular" <%= item.is_popular ? 'checked' : '' %>> Популярное</label>
              <label class="check"><input type="checkbox" name="is_new" <%= item.is_new ? 'checked' : '' %>> Новинка</label>
              <label class="check"><input type="checkbox" name="is_active" <%= item.is_active ? 'checked' : '' %>> Показывать</label>
            </div>
            <div class="card-actions">
              <button class="btn">Сохранить</button>
              <button class="btn danger" formaction="/admin/items/<%= item.id %>/delete" onclick="return confirm('Удалить позицию?')">Удалить</button>
            </div>
          </form>
        <% }) %>
      </div>
    </section>
  </main>
</body>
</html>
