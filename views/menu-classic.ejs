<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title><%= settings.restaurant_name %> — меню</title>

  <link rel="stylesheet" href="/public/css/style-classic.css?v=<%= Date.now() %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>

  <style>
    :root { --accent: <%= settings.accent_color || '#b89b5e' %>; }
  </style>
</head>

<body class="classic-body">
  <div class="classic-page">

    <header class="classic-hero">
      <div class="classic-logo"><%= settings.restaurant_name || 'LE CAFÉ' %></div>
      <div class="classic-subtitle">
        <span></span>
        QR меню
        <span></span>
      </div>
    </header>

    <nav class="classic-tabs" id="categoryTabs" aria-label="Разделы меню">
      <% categories.forEach((cat, index) => { %>
        <% if (cat.items.length) { %>
          <a href="#cat-<%= cat.id %>" class="classic-tab <%= index === 0 ? 'active' : '' %>">
            <%= cat.title %>
          </a>
        <% } %>
      <% }) %>
    </nav>

    <main class="classic-wrap">
      <% categories.forEach(cat => { if (cat.items.length) { %>
        <section class="classic-section" id="cat-<%= cat.id %>">
          <div class="classic-section-head">
            <h2><%= cat.title %></h2>
            <% if (cat.description) { %><p><%= cat.description %></p><% } %>
          </div>

          <%
            /* Группируем позиции по subtitle_group */
            const grouped = [];
            const groupMap = {};
            cat.items.forEach(item => {
              const g = (item.subtitle_group || '').trim();
              if (!g) {
                grouped.push({ group: null, items: [item], _single: true });
              } else {
                if (!groupMap[g]) {
                  groupMap[g] = { group: g, items: [] };
                  grouped.push(groupMap[g]);
                }
                groupMap[g].items.push(item);
              }
            });
            /* Схлопываем одиночные (без группы) в один блок в начале */
            const singles = grouped.filter(g => g._single).map(g => g.items[0]);
            const groups  = grouped
              .filter(g => !g._single)
              .sort((a, b) => {
                const posA = Math.min(...a.items.map(i => Number(i.subtitle_group_position || 0)));
                const posB = Math.min(...b.items.map(i => Number(i.subtitle_group_position || 0)));
                return posA - posB;
              });
          %>

          <% if (singles.length) { %>
            <div class="classic-list">
              <% singles.forEach(item => { %>
                <%- include('_card', { item, settings }) %>
              <% }) %>
            </div>
          <% } %>

          <% groups.forEach((grp, gi) => { %>
            <div class="sub-group" id="sg-<%= cat.id %>-<%= gi %>">
              <button
                class="sub-group-toggle"
                aria-expanded="true"
                aria-controls="sgl-<%= cat.id %>-<%= gi %>"
                onclick="toggleGroup(this)"
              >
                <span class="sub-group-title"><%= grp.group %></span>
                <svg class="sub-group-icon" width="18" height="18" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <div class="sub-group-list" id="sgl-<%= cat.id %>-<%= gi %>">
                <div class="classic-list">
                  <% grp.items.forEach(item => { %>
                    <%- include('_card', { item, settings }) %>
                  <% }) %>
                </div>
              </div>
            </div>
          <% }) %>

        </section>
      <% } }) %>
    </main>

    <footer class="classic-footer">
      Смачно. Свіжо. По-справжньому.
    </footer>
  </div>

  <!-- LIGHTBOX -->
  <div class="lb-overlay" id="lb" role="dialog" aria-modal="true" aria-label="Просмотр фото" onclick="lbClose(event)">
    <button class="lb-close" onclick="lbHide()" aria-label="Закрыть">&times;</button>
    <img class="lb-img" id="lbImg" src="" alt="">
  </div>

  <script src="/public/js/menu-classic.js?v=<%= Date.now() %>"></script>
</body>
</html>
